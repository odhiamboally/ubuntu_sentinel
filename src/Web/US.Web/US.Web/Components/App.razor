<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["US.Web.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        window.ubuntuSentinelSetLanguage = function (language, targetUrl) {
            localStorage.setItem('ubuntu-sentinel-language', language === 'fr' ? 'fr' : 'en');
            if (targetUrl) {
                window.location.href = targetUrl;
                return;
            }

            window.location.reload();
        };

        window.ubuntuSentinelLogout = function () {
            localStorage.removeItem('ubuntu-sentinel-role');
            localStorage.removeItem('ubuntu-sentinel-role-username');
            localStorage.removeItem('ubuntu-sentinel-role-display');
        };

        window.ubuntuSentinelApplyShellState = function () {
            const language = localStorage.getItem('ubuntu-sentinel-language') || 'en';
            document.querySelectorAll('[data-language-toggle]').forEach(button => {
                button.classList.toggle('active', button.getAttribute('data-language-toggle') === language);
            });

            const role = localStorage.getItem('ubuntu-sentinel-role') || 'Reporter';
            const display = localStorage.getItem('ubuntu-sentinel-role-display') || role;
            const roleLabel = role === 'Admin'
                ? (language === 'fr' ? 'Administrateur' : 'Admin')
                : role === 'Validator'
                    ? (language === 'fr' ? 'Validateur' : 'Validator')
                    : (language === 'fr' ? 'Declarant' : 'Reporter');
            const initials = display
                .split(' ')
                .filter(Boolean)
                .slice(0, 2)
                .map(part => part[0])
                .join('')
                .toUpperCase() || roleLabel[0];

            const displayElement = document.getElementById('ubuntu-role-display');
            const labelElement = document.getElementById('ubuntu-role-label');
            const initialsElement = document.getElementById('ubuntu-role-initials');

            if (displayElement) displayElement.textContent = display;
            if (labelElement) labelElement.textContent = roleLabel;
            if (initialsElement) initialsElement.textContent = initials;
        };

        document.addEventListener('DOMContentLoaded', window.ubuntuSentinelApplyShellState);
        document.addEventListener('visibilitychange', window.ubuntuSentinelApplyShellState);
        setTimeout(window.ubuntuSentinelApplyShellState, 0);
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
