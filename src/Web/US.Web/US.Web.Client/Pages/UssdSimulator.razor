@page "/intake/ussd"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ClientAppLayout
@implements IDisposable
@inject Services.AppLanguageService Language
@inject Services.UiTextService Text
@inject IJSRuntime JsRuntime

<PageTitle>@T("Ussd.Title") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <section class="hero-band dashboard-hero">
        <div>
            <p class="eyebrow">@T("Ussd.FieldIntake")</p>
            <h1>@T("Ussd.SimulatorTitle")</h1>
            <p class="lede">@T("Ussd.SimulatorLede")</p>
        </div>
        <MudButton Href="/submit" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@T("Ussd.UseWebForm")</MudButton>
    </section>

    <UssdIntakePanel LanguageCode="@_language" />
</main>

@code {
    private string _language = "en";

    protected override async Task OnInitializedAsync()
    {
        await Language.InitializeAsync(JsRuntime);
        _language = Language.CurrentLanguage;
        Language.LanguageChanged += HandleLanguageChanged;
    }

    private string T(string key) => Text.Text(_language, key);

    private void HandleLanguageChanged()
    {
        _language = Language.CurrentLanguage;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Language.LanguageChanged -= HandleLanguageChanged;
    }
}
