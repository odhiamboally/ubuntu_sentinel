@page "/submit"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ClientAppLayout
@using US.SharedKernel.Contracts.Regions
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@using US.SharedKernel.Inference
@using MudBlazor
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.OfflineReportQueue OfflineQueue
@inject Services.UiTextService Text
@inject Services.AppLanguageService Language
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IssueTypeInferenceService IssueTypeInference
@implements IAsyncDisposable

<PageTitle>@T("Submit.Title") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <section class="hero-band dashboard-hero">
        <div>
            <p class="eyebrow">@T("Submit.Eyebrow")</p>
            <h1>@T("Submit.Title")</h1>
            <p class="lede">@T("Submit.Lede")</p>
        </div>
        <MudButton Size="Size.Small"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Dialpad"
                   OnClick="OpenUssdDialogAsync">
            @T("Submit.UseUssd")
        </MudButton>
    </section>

    <section class="safety-note">
        <strong>@T("Submit.SafetyTitle")</strong>
        @T("Submit.SafetyBody")
    </section>

    <section class="workspace-grid">
        <EditForm Model="_model" OnSubmit="SubmitAsync" class="report-form">
            @if (_validationErrors.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="full-span">
                    @foreach (var error in _validationErrors)
                    {
                        <p>@error</p>
                    }
                </MudAlert>
            }

            <MudSelect T="string" Value="_model.RegionCode" ValueChanged="OnRegionChanged" Label="@RequiredLabel("Common.Region")" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                @foreach (var region in _regions)
                {
                    <MudSelectItem Value="@region.Code">@region.Name</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_model.LocationName" Label="@RequiredLabel("Common.Location")" Placeholder="@T("Submit.LocationPlaceholder")" Margin="Margin.Dense" Variant="Variant.Outlined" />

            <MudSelect T="IssueType?" @bind-Value="_model.IssueTypeHint" Label="@RequiredLabel("Common.IssueType")" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                @foreach (var issueType in Enum.GetValues<IssueType>())
                {
                    <MudSelectItem T="IssueType?" Value="@issueType">@Text.IssueType(_model.LanguageCode, issueType)</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="UrgencyLevel?" @bind-Value="_model.UrgencyHint" Label="@RequiredLabel("Common.Urgency")" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                @foreach (var urgency in Enum.GetValues<UrgencyLevel>())
                {
                    <MudSelectItem T="UrgencyLevel?" Value="@urgency">@Text.Urgency(_model.LanguageCode, urgency)</MudSelectItem>
                }
            </MudSelect>

            <MudTextField T="string"
                          Value="@_model.Description"
                          ValueChanged="OnDescriptionChanged"
                          Label="@RequiredLabel("Submit.WhatHappened")"
                          Placeholder="@T("Submit.DescriptionPlaceholder")"
                          Lines="6"
                          Class="full-span"
                          Immediate="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined" />

            @if (_issueSuggestion?.SuggestedType is { } suggestedType)
            {
                <MudAlert Severity="@SuggestionSeverity" Variant="Variant.Outlined" Dense="true" Class="full-span inference-alert">
                    <div class="inference-row">
                        <span>
                            @T("Submit.SuggestedIssue"): <strong>@Text.IssueType(_model.LanguageCode, suggestedType)</strong>
                            (@_issueSuggestion.Confidence.ToString("0.00")) · @T("Submit.Signals"): @string.Join(", ", _issueSuggestion.Signals.Take(4))
                        </span>
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => UseIssueSuggestion(suggestedType))">
                            @T("Submit.UseSuggestion")
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default" OnClick="IgnoreIssueSuggestion">
                            @T("Submit.IgnoreSuggestion")
                        </MudButton>
                    </div>
                </MudAlert>
            }

            <div class="check-row full-span">
                <MudCheckBox T="bool" @bind-Value="_model.WomenLed" Dense="true" Label="@T("Submit.WomenLed")" />
                <MudCheckBox T="bool" @bind-Value="_model.YouthLed" Dense="true" Label="@T("Submit.YouthLed")" />
                <MudCheckBox T="bool" @bind-Value="_model.IsSensitive" Dense="true" Label="@T("Submit.Sensitive")" />
            </div>

            <div class="form-action-row full-span">
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isSubmitting" Size="Size.Small">
                    @(_isSubmitting ? T("Submit.Submitting") : T("Submit.Submit"))
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo("/reports"))">
                    @T("Common.Cancel")
                </MudButton>
            </div>
        </EditForm>

        <aside class="context-panel">
            <h2>@T("Submit.RegionContext")</h2>
            @if (CurrentRegion is null)
            {
                <p>@T("Submit.LoadingRegions")</p>
            }
            else
            {
                <h3>@CurrentRegion.Name</h3>
                <p>@CurrentRegion.Description</p>
                <dl>
                    <dt>@T("Submit.RegionalBodies")</dt>
                    <dd>@string.Join(", ", CurrentRegion.RegionalBodies)</dd>
                    <dt>@T("Submit.EscalationPathways")</dt>
                    <dd>@CurrentRegion.EscalationSummary</dd>
                    @if (CurrentRegion.RelevantSources.Count > 0)
                    {
                        <dt>Relevant sources</dt>
                        <dd>
                            <ul class="region-source-list">
                                @foreach (var source in CurrentRegion.RelevantSources)
                                {
                                    <li>
                                        <span>@source.Title</span>
                                        <small>@source.Type</small>
                                    </li>
                                }
                            </ul>
                        </dd>
                    }
                </dl>
            }
        </aside>
    </section>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <section class="error-panel">
            @_errorMessage
        </section>
    }
</main>

@code {
    private SubmitReportRequest _model = new()
    {
        RegionCode = "drc",
        LanguageCode = "fr",
        UrgencyHint = UrgencyLevel.Medium
    };

    private IReadOnlyList<RegionProfileDto> _regions = [];
    private readonly List<string> _validationErrors = [];
    private bool _isSubmitting;
    private bool _isOnline = true;
    private int _pendingCount;
    private string? _errorMessage;
    private IssueTypeInferenceResultDto? _issueSuggestion;
    private string? _ignoredSuggestionKey;
    private IJSObjectReference? _connectivityModule;
    private IJSObjectReference? _connectivityRegistration;
    private DotNetObjectReference<SubmitReport>? _dotNetReference;

    private RegionProfileDto? CurrentRegion =>
        _regions.FirstOrDefault(region => region.Code == _model.RegionCode);

    protected override async Task OnInitializedAsync()
    {
        await Language.InitializeAsync(JsRuntime);
        Language.LanguageChanged += HandleLanguageChanged;
        _model = _model with { LanguageCode = Language.CurrentLanguage };

        _regions = await ApiClient.GetRegionsAsync();
        _pendingCount = await OfflineQueue.GetPendingCountAsync();
        var defaultRegion = _regions.FirstOrDefault(region => region.Code == _model.RegionCode) ?? _regions.FirstOrDefault();

        if (defaultRegion is not null)
        {
            _model = _model with
            {
                RegionCode = defaultRegion.Code,
                LanguageCode = Language.CurrentLanguage
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _connectivityModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./connectivity.js");
        _dotNetReference = DotNetObjectReference.Create(this);
        _connectivityRegistration = await _connectivityModule.InvokeAsync<IJSObjectReference>("register", _dotNetReference);
        _isOnline = await _connectivityModule.InvokeAsync<bool>("isOnline");
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
        _validationErrors.Clear();
        if (!ValidateForm())
        {
            var validationMessage = T("Submit.ValidationError");
            Snackbar.Add(validationMessage, Severity.Error);
            await ShowFeedbackAsync(T("Common.Error"), validationMessage, Icons.Material.Filled.Error, Color.Error, T("Common.Ok"));
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var report = await ApiClient.SubmitReportAsync(_model);
            var languageCode = _model.LanguageCode;
            var successMessage = T("Submit.SuccessDetail");
            Snackbar.Add(T("Submit.Success"), Severity.Success);
            _model = _model with { Description = string.Empty, LocationName = string.Empty };
            _issueSuggestion = null;
            _isSubmitting = false;
            StateHasChanged();
            await Task.Yield();
            await ShowFeedbackAsync(
                Text.Text(languageCode, "Submit.SuccessTitle"),
                successMessage,
                Icons.Material.Filled.CheckCircle,
                Color.Success,
                Text.Text(languageCode, "Common.Ok"));
            Navigation.NavigateTo("/reports");
        }
        catch
        {
            await OfflineQueue.EnqueueAsync(_model);
            _pendingCount = await OfflineQueue.GetPendingCountAsync();
            var languageCode = _model.LanguageCode;
            var offlineMessage = _isOnline ? T("Submit.SubmitFailed") : T("Submit.SavedOffline");
            Snackbar.Add(offlineMessage, Severity.Warning);
            _model = _model with { Description = string.Empty, LocationName = string.Empty };
            _issueSuggestion = null;
            _isSubmitting = false;
            StateHasChanged();
            await Task.Yield();
            await ShowFeedbackAsync(
                Text.Text(languageCode, "Submit.OfflineTitle"),
                offlineMessage,
                Icons.Material.Filled.CloudDone,
                Color.Warning,
                Text.Text(languageCode, "Common.Ok"));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    [JSInvokable]
    public async Task NotifyOnlineStatusChanged(bool isOnline)
    {
        _isOnline = isOnline;

        if (isOnline && _pendingCount > 0)
        {
            await SyncPendingAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncPendingAsync()
    {
        _errorMessage = null;

        try
        {
            var result = await OfflineQueue.SyncAsync();
            _pendingCount = await OfflineQueue.GetPendingCountAsync();
            var syncMessage = result.Remaining == 0
                ? Text.Format(_model.LanguageCode, "Submit.SyncedAll", result.Synced)
                : Text.Format(_model.LanguageCode, "Submit.SyncedSome", result.Synced, result.Attempted, result.Remaining);
            Snackbar.Add(syncMessage, result.Remaining == 0 ? Severity.Success : Severity.Warning);
            await ShowFeedbackAsync(T("Submit.SyncTitle"), syncMessage, Icons.Material.Filled.Sync, Color.Success, T("Common.Ok"));
        }
        catch
        {
            _errorMessage = T("Submit.SubmitFailed");
            Snackbar.Add(_errorMessage, Severity.Warning);
        }
    }

    private void OnRegionChanged(string regionCode)
    {
        _model = _model with
        {
            RegionCode = regionCode
        };

        _validationErrors.Clear();
    }

    private void OnDescriptionChanged(string value)
    {
        _model.Description = value;
        UpdateIssueSuggestion();
    }

    private void UpdateIssueSuggestion()
    {
        var suggestion = IssueTypeInference.Infer(_model.Description);
        _issueSuggestion = SuggestionKey(suggestion) == _ignoredSuggestionKey ? null : suggestion;
    }

    private void UseIssueSuggestion(IssueType issueType)
    {
        _model.IssueTypeHint = issueType;
        _ignoredSuggestionKey = null;
        _issueSuggestion = null;
        _validationErrors.Clear();
    }

    private void IgnoreIssueSuggestion()
    {
        _ignoredSuggestionKey = SuggestionKey(_issueSuggestion);
        _issueSuggestion = null;
    }

    private static string? SuggestionKey(IssueTypeInferenceResultDto? suggestion)
    {
        return suggestion?.SuggestedType is null
            ? null
            : $"{suggestion.SuggestedType}:{string.Join("|", suggestion.Signals)}";
    }

    private bool ValidateForm()
    {
        if (string.IsNullOrWhiteSpace(_model.Description))
        {
            _validationErrors.Add(T("Submit.DescriptionRequired"));
        }
        else if (string.IsNullOrWhiteSpace(_model.LocationName))
        {
            _validationErrors.Add(T("Submit.LocationRequired"));
        }
        else if (_model.Description.Trim().Length < 10)
        {
            _validationErrors.Add(T("Submit.DescriptionTooShort"));
        }
        else if (_model.Description.Length > 4_000)
        {
            _validationErrors.Add(T("Submit.DescriptionTooLong"));
        }
        else if (_model.IssueTypeHint is null or IssueType.Other)
        {
            _validationErrors.Add(T("Submit.IssueTypeRequired"));
        }

        return _validationErrors.Count == 0;
    }

    private string T(string key) => Text.Text(_model.LanguageCode, key);

    private void HandleLanguageChanged()
    {
        _model = _model with { LanguageCode = Language.CurrentLanguage };
        _validationErrors.Clear();
        _ = InvokeAsync(StateHasChanged);
    }

    private string RequiredLabel(string key) => $"{T(key)} *";

    private Severity SuggestionSeverity => _issueSuggestion?.Tier switch
    {
        ConfidenceTier.High => Severity.Success,
        ConfidenceTier.Medium => Severity.Info,
        _ => Severity.Warning
    };

    private async Task ShowFeedbackAsync(string title, string message, string icon, Color iconColor, string okText)
    {
        var parameters = new DialogParameters<ActionFeedbackDialog>
        {
            { dialog => dialog.Title, title },
            { dialog => dialog.Message, message },
            { dialog => dialog.Icon, icon },
            { dialog => dialog.IconColor, iconColor },
            { dialog => dialog.OkText, okText }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = false
        };

        var dialog = await DialogService.ShowAsync<ActionFeedbackDialog>(string.Empty, parameters, options);
        await dialog.Result;
    }

    private async Task OpenUssdDialogAsync()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = false,
            CloseButton = true
        };

        var parameters = new DialogParameters<UssdIntakeDialog>
        {
            { dialog => dialog.LanguageCode, _model.LanguageCode },
            { dialog => dialog.RegionCode, _model.RegionCode }
        };

        var dialog = await DialogService.ShowAsync<UssdIntakeDialog>(T("Submit.UseUssd"), parameters, options);
        await dialog.Result;
    }

    public async ValueTask DisposeAsync()
    {
        Language.LanguageChanged -= HandleLanguageChanged;

        if (_connectivityRegistration is not null)
        {
            await _connectivityRegistration.InvokeVoidAsync("dispose");
            await _connectivityRegistration.DisposeAsync();
        }

        if (_connectivityModule is not null)
        {
            await _connectivityModule.DisposeAsync();
        }

        _dotNetReference?.Dispose();
    }
}
