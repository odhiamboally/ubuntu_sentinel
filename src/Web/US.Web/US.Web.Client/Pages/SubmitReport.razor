@page "/submit"
@rendermode InteractiveWebAssembly
@using US.SharedKernel.Contracts.Regions
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.OfflineReportQueue OfflineQueue
@inject Services.UiTextService Text
@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

<PageTitle>@T("Submit.Title") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <section class="hero-band">
        <p class="eyebrow">@T("Submit.Eyebrow")</p>
        <h1>@T("Submit.Title")</h1>
        <p class="lede">@T("Submit.Lede")</p>
    </section>

    <section class="workspace-grid">
        <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="report-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>
                @T("Common.Region")
                <InputSelect @bind-Value="_model.RegionCode">
                    @foreach (var region in _regions)
                    {
                        <option value="@region.Code">@region.Name</option>
                    }
                </InputSelect>
            </label>

            <label>
                @T("Common.Language")
                <InputSelect @bind-Value="_model.LanguageCode">
                    @foreach (var language in CurrentLanguages)
                    {
                        <option value="@language.Code">@language.Name</option>
                    }
                </InputSelect>
            </label>

            <label>
                @T("Common.Location")
                <InputText @bind-Value="_model.LocationName" placeholder="@T("Submit.LocationPlaceholder")" />
            </label>

            <label>
                @T("Common.IssueType")
                <InputSelect @bind-Value="_model.IssueTypeHint">
                    @foreach (var issueType in Enum.GetValues<IssueType>())
                    {
                        <option value="@issueType">@Text.IssueType(_model.LanguageCode, issueType)</option>
                    }
                </InputSelect>
            </label>

            <label class="full-span">
                @T("Submit.WhatHappened")
                <InputTextArea @bind-Value="_model.Description" rows="7" placeholder="@T("Submit.DescriptionPlaceholder")" />
            </label>

            <div class="check-row full-span">
                <label><InputCheckbox @bind-Value="_model.WomenLed" /> @T("Submit.WomenLed")</label>
                <label><InputCheckbox @bind-Value="_model.YouthLed" /> @T("Submit.YouthLed")</label>
                <label><InputCheckbox @bind-Value="_model.IsSensitive" /> @T("Submit.Sensitive")</label>
            </div>

            <button type="submit" disabled="@_isSubmitting">@(_isSubmitting ? T("Submit.Submitting") : T("Submit.Submit"))</button>
        </EditForm>

        <aside class="context-panel">
            <div class="sync-strip">
                <span class="@(_isOnline ? "status-online" : "status-offline")">@(_isOnline ? T("Common.Online") : T("Common.Offline"))</span>
                <span>@_pendingCount @T("Common.Pending")</span>
                <button type="button" @onclick="SyncPendingAsync" disabled="@(_isSyncing || _pendingCount == 0)">
                    @(_isSyncing ? T("Common.Syncing") : T("Common.Sync"))
                </button>
            </div>

            <h2>@T("Submit.RegionContext")</h2>
            @if (CurrentRegion is null)
            {
                <p>@T("Submit.LoadingRegions")</p>
            }
            else
            {
                <h3>@CurrentRegion.Name</h3>
                <p>@CurrentRegion.Description</p>
                <dl>
                    <dt>@T("Submit.RegionalBodies")</dt>
                    <dd>@string.Join(", ", CurrentRegion.RegionalBodies)</dd>
                    <dt>@T("Submit.EscalationPathways")</dt>
                    <dd>@string.Join(" -> ", CurrentRegion.EscalationPathways)</dd>
                </dl>
            }
        </aside>
    </section>

    @if (_submittedReport is not null)
    {
        <section class="result-panel">
            <p class="eyebrow">@T("Submit.Submitted")</p>
            <h2>@T("Submit.Queued")</h2>
            <p><strong>ID:</strong> @_submittedReport.Id</p>
            <p><strong>@T("Common.Status"):</strong> @_submittedReport.Status</p>
            <p><strong>@T("Common.Urgency"):</strong> @_submittedReport.Urgency</p>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_syncMessage))
    {
        <section class="result-panel">
            @_syncMessage
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <section class="error-panel">
            @_errorMessage
        </section>
    }
</main>

@code {
    private SubmitReportRequest _model = new()
    {
        RegionCode = "drc",
        LanguageCode = "fr",
        IssueTypeHint = IssueType.BrokenPromise
    };

    private IReadOnlyList<RegionProfileDto> _regions = [];
    private ReportDto? _submittedReport;
    private bool _isSubmitting;
    private bool _isSyncing;
    private bool _isOnline = true;
    private int _pendingCount;
    private string? _syncMessage;
    private string? _errorMessage;
    private IJSObjectReference? _connectivityModule;
    private IJSObjectReference? _connectivityRegistration;
    private DotNetObjectReference<SubmitReport>? _dotNetReference;

    private RegionProfileDto? CurrentRegion =>
        _regions.FirstOrDefault(region => region.Code == _model.RegionCode);

    private IReadOnlyList<LanguageOptionDto> CurrentLanguages =>
        CurrentRegion?.Languages ?? [new LanguageOptionDto { Code = "en", Name = "English", IsDefault = true }];

    protected override async Task OnInitializedAsync()
    {
        _regions = await ApiClient.GetRegionsAsync();
        _pendingCount = await OfflineQueue.GetPendingCountAsync();
        var defaultRegion = _regions.FirstOrDefault(region => region.Code == _model.RegionCode) ?? _regions.FirstOrDefault();

        if (defaultRegion is not null)
        {
            _model = _model with
            {
                RegionCode = defaultRegion.Code,
                LanguageCode = defaultRegion.Languages.FirstOrDefault(language => language.IsDefault)?.Code
                    ?? defaultRegion.Languages.FirstOrDefault()?.Code
                    ?? "en"
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _connectivityModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./connectivity.js");
        _dotNetReference = DotNetObjectReference.Create(this);
        _connectivityRegistration = await _connectivityModule.InvokeAsync<IJSObjectReference>("register", _dotNetReference);
        _isOnline = await _connectivityModule.InvokeAsync<bool>("isOnline");
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;
        _submittedReport = null;
        _syncMessage = null;

        try
        {
            _submittedReport = await ApiClient.SubmitReportAsync(_model);
            _model = _model with { Description = string.Empty, LocationName = string.Empty };
        }
        catch
        {
            await OfflineQueue.EnqueueAsync(_model);
            _pendingCount = await OfflineQueue.GetPendingCountAsync();
            _syncMessage = T("Submit.SavedOffline");
            _model = _model with { Description = string.Empty, LocationName = string.Empty };
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    [JSInvokable]
    public async Task NotifyOnlineStatusChanged(bool isOnline)
    {
        _isOnline = isOnline;

        if (isOnline && _pendingCount > 0)
        {
            await SyncPendingAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncPendingAsync()
    {
        _isSyncing = true;
        _errorMessage = null;
        _syncMessage = null;

        try
        {
            var result = await OfflineQueue.SyncAsync();
            _pendingCount = await OfflineQueue.GetPendingCountAsync();
            _syncMessage = result.Remaining == 0
                ? Text.Format(_model.LanguageCode, "Submit.SyncedAll", result.Synced)
                : Text.Format(_model.LanguageCode, "Submit.SyncedSome", result.Synced, result.Attempted, result.Remaining);
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private string T(string key) => Text.Text(_model.LanguageCode, key);

    public async ValueTask DisposeAsync()
    {
        if (_connectivityRegistration is not null)
        {
            await _connectivityRegistration.InvokeVoidAsync("dispose");
            await _connectivityRegistration.DisposeAsync();
        }

        if (_connectivityModule is not null)
        {
            await _connectivityModule.DisposeAsync();
        }

        _dotNetReference?.Dispose();
    }
}
