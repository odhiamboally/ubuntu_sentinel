@page "/reports/{ReportId:guid}/brief"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ClientAppLayout
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@using MudBlazor
@using Microsoft.JSInterop
@using System.Net
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.UiTextService Text
@inject Services.AppLanguageService Language
@inject Services.AppRoleService Roles
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>@T("Brief.PageTitle") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <div class="brief-toolbar no-print">
        <MudButton OnClick="@(() => Navigation.NavigateTo("/reports"))" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack">
            @T("Common.BackToReports")
        </MudButton>
    </div>

    <section class="hero-band brief-hero">
        <div>
            <p class="eyebrow">@T("Brief.Eyebrow")</p>
            <h1>@BriefTitle</h1>
            <p class="lede">@BriefLede</p>
        </div>
        @if (IsAdminView)
        {
            <div class="brief-export-actions no-print">
                <MudButton Href="@BriefPdfUrl" Target="_blank" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PictureAsPdf" Disabled="@(_isLoading || _result is null)">
                    @T("Brief.PrintPdf")
                </MudButton>

                <MudButton Href="@BriefJsonUrl" Target="_blank" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.DataObject" Disabled="@(_isLoading || _result is null)">
                    @T("Brief.ExportJson")
                </MudButton>
            </div>
        }
    </section>

    @if (!IsRestrictedView)
    {
        <section class="safety-note @(IsValidationBacked ? "validated-note" : null)">
            <strong>@BriefSafetyTitle</strong>
            @BriefSafetyBody
        </section>
    }

    @if (_isLoading)
    {
        <section class="empty-state">
            <h2>@T("Brief.GeneratingTitle")</h2>
            <p>@T("Brief.GeneratingBody")</p>
        </section>
    }
    else if (IsRestrictedView)
    {
        <section class="empty-state">
            <h2>@T("Brief.RestrictedTitle")</h2>
            <p>@T("Brief.RestrictedBody")</p>
        </section>
    }
    else if (_result is null)
    {
        <section class="error-panel">
            @T("Brief.LoadFailed")
        </section>
    }
    else
    {
        @if (IsAdminView && !string.IsNullOrWhiteSpace(_result.FallbackReason))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="pipeline-alert">
                <div class="pipeline-alert-content">
                    <strong>@T("Pipeline.FallbackTitle")</strong>
                    <span>@LocalizedFallbackReason</span>
                </div>
            </MudAlert>
        }

        <section class="brief-public-meta">
            <span>
                <strong>@T("Common.Status")</strong>
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(_report?.Status ?? ReportStatus.Submitted)" Variant="Variant.Filled">
                    @Text.Status(_report?.LanguageCode ?? "en", _report?.Status ?? ReportStatus.Submitted)
                </MudChip>
            </span>
            <span>
                <strong>@T("Common.IssueType")</strong>
                <MudChip T="string" Size="Size.Small" Class="brief-chip issue-chip" Variant="Variant.Filled">
                    @Text.IssueType(_report?.LanguageCode ?? "en", _result.IssueType)
                </MudChip>
            </span>
            <span>
                <strong>@T("Common.Urgency")</strong>
                <MudChip T="string" Size="Size.Small" Color="@UrgencyColor(_result.Urgency)" Variant="Variant.Filled">
                    @Text.Urgency(_report?.LanguageCode ?? "en", _result.Urgency)
                </MudChip>
            </span>
        </section>

        @if (IsAdminView)
        {
            <section class="brief-summary-row admin-only-panel">
            <div class="brief-status-card">
                <div>
                    <span>@T("Common.Status")</span>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(_report?.Status ?? ReportStatus.Submitted)" Variant="Variant.Filled">
                        @Text.Status(_report?.LanguageCode ?? "en", _report?.Status ?? ReportStatus.Submitted)
                    </MudChip>
                </div>
                <div>
                    <span>@T("Common.IssueType")</span>
                    <MudChip T="string" Size="Size.Small" Class="brief-chip issue-chip" Variant="Variant.Filled">
                        @Text.IssueType(_report?.LanguageCode ?? "en", _result.IssueType)
                    </MudChip>
                </div>
                <div>
                    <span>@T("Common.Urgency")</span>
                    <MudChip T="string" Size="Size.Small" Color="@UrgencyColor(_result.Urgency)" Variant="Variant.Filled">
                        @Text.Urgency(_report?.LanguageCode ?? "en", _result.Urgency)
                    </MudChip>
                </div>
                <div>
                    <span>@T("Pipeline.Confidence")</span>
                    <MudChip T="string" Size="Size.Small" Class="brief-chip confidence-chip" Variant="Variant.Filled">
                        @_result.Confidence.ToString("0.00")
                    </MudChip>
                </div>
                <div>
                    <span>@T("Brief.ValidationGate")</span>
                    <MudChip T="string" Size="Size.Small" Color="@(IsValidationBacked ? Color.Success : Color.Warning)" Variant="Variant.Filled">
                        @(IsValidationBacked ? T("Brief.Complete") : T("Brief.Draft"))
                    </MudChip>
                </div>
                <div>
                    <span>@T("Pipeline.Mode")</span>
                    <MudChip T="string" Size="Size.Small" Color="@PipelineModeColor" Variant="Variant.Filled">
                        @LocalizedPipelineMode
                    </MudChip>
                </div>
            </div>

            <div class="brief-panel validation-gate-panel">
                <div>
                    <p class="eyebrow">@T("Brief.HumanValidationGate")</p>
                    <h2>@(IsValidationBacked ? T("Brief.ReadyTitle") : T("Brief.NotReadyTitle"))</h2>
                    <p>@ValidationGateText</p>
                </div>
                <div class="validation-gate-checks">
                    @foreach (var check in ValidationGateChecks)
                    {
                        <MudChip T="string" Size="Size.Small" Color="@(check.Done ? Color.Success : Color.Default)" Variant="Variant.Filled" Icon="@(check.Done ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                            @check.Label
                        </MudChip>
                    }
                </div>
            </div>
        </section>
        }

        <section class="brief-stack">
            @if (IsAdminView && _result.PolicyMatch is not null)
            {
                <article class="brief-panel source-panel admin-only-panel">
                    <p class="eyebrow">@T("Brief.SourceUsed")</p>
                    <h2>@_result.PolicyMatch.DocumentTitle</h2>
                    <p><strong>@_result.PolicyMatch.ArticleReference</strong> · @_result.PolicyMatch.DocumentType · similarity @_result.PolicyMatch.Similarity.ToString("0.00")</p>
                    <p>@_result.PolicyMatch.Source · @_result.PolicyMatch.SourceUrl</p>
                </article>
            }

            <article class="brief-panel">
                <h2>@(IsValidationBacked ? T("Brief.ExportReady") : T("Brief.InternalDraft"))</h2>
                <div class="brief-document">
                    @foreach (var line in BriefLines)
                    {
                        @switch (line.Kind)
                        {
                            case BriefLineKind.Title:
                                <h1>@line.Text</h1>
                                break;
                            case BriefLineKind.Section:
                                <h2>@line.Text</h2>
                                break;
                            case BriefLineKind.Bullet:
                                <p class="brief-bullet">@((MarkupString)FormatInline(line.Text))</p>
                                break;
                            case BriefLineKind.Rule:
                                <hr />
                                break;
                            case BriefLineKind.Note:
                                <p class="brief-note">@((MarkupString)FormatInline(line.Text))</p>
                                break;
                            case BriefLineKind.Empty:
                                <div class="brief-line-space"></div>
                                break;
                            default:
                                <p>@((MarkupString)FormatInline(line.Text))</p>
                                break;
                        }
                    }
                </div>
            </article>
        </section>
    }
</main>

@code {
    [Parameter]
    public Guid ReportId { get; set; }

    private ReportPipelineResultDto? _result;
    private ReportDto? _report;
    private bool _isLoading = true;
    private bool _isRestricted = true;
    private string _language = "en";

    private string BriefJsonUrl => ApiClient.GetBriefJsonUrl(ReportId, IsAdminView);
    private string BriefPdfUrl => ApiClient.GetBriefPdfUrl(ReportId, IsAdminView);
    private bool IsAdminView => Roles.IsAdmin;
    private bool IsRestrictedView => _isRestricted;

    private bool IsValidationBacked =>
        _report?.Status == ReportStatus.Approved &&
        _report.ValidationChecks.IsComplete;

    private string BriefTitle => IsRestrictedView
        ? T("Brief.RestrictedTitle")
        : IsValidationBacked
            ? T("Brief.ValidatedTitle")
            : T("Brief.DraftTitle");

    private string BriefLede => IsRestrictedView
        ? T("Brief.RestrictedBody")
        : IsValidationBacked
            ? T("Brief.ValidatedLede")
            : T("Brief.DraftLede");

    private string BriefSafetyTitle => IsValidationBacked
        ? T("Brief.ValidatedSafetyTitle")
        : T("Brief.DraftSafetyTitle");

    private string BriefSafetyBody => IsValidationBacked
        ? T("Brief.ValidatedSafetyBody")
        : T("Brief.DraftSafetyBody");

    private string ValidationGateText => IsValidationBacked
        ? T("Brief.ValidationComplete")
        : T("Brief.ValidationPending");

    private IReadOnlyList<(string Label, bool Done)> ValidationGateChecks =>
    [
        (T("Validate.ConsentCheck"), _report?.ValidationChecks.ConsentConfirmed == true),
        (T("Validate.LocationCheck"), _report?.ValidationChecks.LocationConfidenceChecked == true),
        (T("Validate.EvidenceCheck"), _report?.ValidationChecks.EvidenceQualityChecked == true),
        (T("Validate.SafetyCheck"), _report?.ValidationChecks.ReporterSafetyChecked == true)
    ];

    private Color PipelineModeColor =>
        string.Equals(_result?.PipelineMode, "OpenAI-backed", StringComparison.OrdinalIgnoreCase)
            ? Color.Success
            : Color.Warning;

    private string LocalizedPipelineMode =>
        _result?.PipelineMode switch
        {
            "OpenAI-backed" => T("Pipeline.ModeOpenAI"),
            "Deterministic fallback" => T("Pipeline.ModeFallback"),
            _ => _result?.PipelineMode ?? string.Empty
        };

    private string LocalizedFallbackReason =>
        _result?.FallbackReason switch
        {
            "OPENAI_API_KEY is not configured." => T("Pipeline.ApiKeyMissing"),
            "OpenAI pipeline failed. Deterministic fallback was used." => T("Pipeline.OpenAiFailed"),
            _ => _result?.FallbackReason ?? string.Empty
        };

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        try
        {
            await Roles.InitializeAsync(Js);
            await Language.InitializeAsync(Js);
            _language = Language.CurrentLanguage;
            if (Roles.IsReporter)
            {
                Navigation.NavigateTo("/");
                return;
            }

            _isRestricted = !Roles.IsAdmin;
            if (_isRestricted)
            {
                return;
            }

            _report = await ApiClient.GetReportAsync(ReportId);
            _result = await ApiClient.GetPipelineResultAsync(ReportId);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string T(string key) => Text.Text(_report?.LanguageCode ?? _language, key);

    private static Color StatusColor(ReportStatus status) => status switch
    {
        ReportStatus.Approved => Color.Success,
        ReportStatus.NeedsFollowUp => Color.Warning,
        ReportStatus.Rejected => Color.Error,
        _ => Color.Info
    };

    private static Color UrgencyColor(UrgencyLevel urgency) => urgency switch
    {
        UrgencyLevel.Critical => Color.Error,
        UrgencyLevel.High => Color.Warning,
        UrgencyLevel.Low => Color.Success,
        _ => Color.Info
    };

    private IReadOnlyList<BriefLine> BriefLines =>
        ParseBrief(_result?.AccountabilityBriefMarkdown ?? string.Empty);

    private static IReadOnlyList<BriefLine> ParseBrief(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
        {
            return [];
        }

        return markdown.Replace("\r\n", "\n").Split('\n')
            .Select(line =>
            {
                var trimmed = line.Trim();
                if (string.IsNullOrWhiteSpace(trimmed))
                {
                    return new BriefLine(BriefLineKind.Empty, string.Empty);
                }

                if (trimmed == "---")
                {
                    return new BriefLine(BriefLineKind.Rule, string.Empty);
                }

                if (trimmed.StartsWith("# ", StringComparison.Ordinal))
                {
                    return new BriefLine(BriefLineKind.Title, trimmed[2..].Trim());
                }

                if (trimmed.StartsWith("## ", StringComparison.Ordinal))
                {
                    return new BriefLine(BriefLineKind.Section, trimmed[3..].Trim());
                }

                if (trimmed.StartsWith("- ", StringComparison.Ordinal))
                {
                    return new BriefLine(BriefLineKind.Bullet, trimmed[2..].Trim());
                }

                if (trimmed.StartsWith("*", StringComparison.Ordinal) && trimmed.EndsWith("*", StringComparison.Ordinal))
                {
                    return new BriefLine(BriefLineKind.Note, trimmed.Trim('*').Trim());
                }

                return new BriefLine(BriefLineKind.Paragraph, trimmed);
            })
            .ToArray();
    }

    private static string FormatInline(string markdown)
    {
        var encoded = WebUtility.HtmlEncode(markdown);
        var parts = encoded.Split("**");
        if (parts.Length < 3)
        {
            return encoded;
        }

        for (var i = 1; i < parts.Length; i += 2)
        {
            parts[i] = $"<strong>{parts[i]}</strong>";
        }

        return string.Concat(parts);
    }

    private sealed record BriefLine(BriefLineKind Kind, string Text);

    private enum BriefLineKind
    {
        Empty,
        Title,
        Section,
        Paragraph,
        Bullet,
        Note,
        Rule
    }
}
