@page "/reports/{ReportId:guid}/brief"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ClientAppLayout
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.UiTextService Text

<PageTitle>Accountability Brief | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <a class="secondary-link back-link" href="/reports">@Text.Text(_report?.LanguageCode ?? "en", "Common.BackToReports")</a>

    <section class="hero-band">
        <p class="eyebrow">AI-assisted accountability</p>
        <h1>@BriefTitle</h1>
        <p class="lede">@BriefLede</p>
    </section>

    <section class="safety-note @(_report?.Status == ReportStatus.Approved ? "validated-note" : null)">
        <strong>@BriefSafetyTitle</strong>
        @BriefSafetyBody
    </section>

    @if (_isLoading)
    {
        <section class="empty-state">
            <h2>Generating brief</h2>
            <p>Running the demo accountability pipeline.</p>
        </section>
    }
    else if (_result is null)
    {
        <section class="error-panel">
            Could not load the accountability brief.
        </section>
    }
    else
    {
        <section class="pipeline-grid">
            <article class="metric-card">
                <span>Status</span>
                <strong>@Text.Status(_report?.LanguageCode ?? "en", _report?.Status ?? ReportStatus.Submitted)</strong>
            </article>
            <article class="metric-card">
                <span>Issue type</span>
                <strong>@Text.IssueType(_report?.LanguageCode ?? "en", _result.IssueType)</strong>
            </article>
            <article class="metric-card">
                <span>Urgency</span>
                <strong>@Text.Urgency(_report?.LanguageCode ?? "en", _result.Urgency)</strong>
            </article>
            <article class="metric-card">
                <span>Confidence</span>
                <strong>@_result.Confidence.ToString("0.00")</strong>
            </article>
        </section>

        <section class="agent-timeline">
            @foreach (var step in _result.Steps)
            {
                <article class="agent-step">
                    <p class="eyebrow">@step.Name</p>
                    <h2>@step.Purpose</h2>
                    <p>@step.Output</p>
                    <span>Confidence @step.Confidence.ToString("0.00")</span>
                </article>
            }
        </section>

        <section class="brief-layout">
            <article class="brief-panel">
                <h2>Pipeline Output</h2>
                <h3>Summary</h3>
                <p>@_result.Summary</p>
                <h3>Gap Analysis</h3>
                <p>@_result.GapAnalysis</p>
                <h3>Reparative Proposal</h3>
                <p>@_result.ReparativeProposal</p>

                @if (_result.Flags.Count > 0)
                {
                    <h3>Flags</h3>
                    <div class="validation-tags">
                        @foreach (var flag in _result.Flags)
                        {
                            <span>@flag</span>
                        }
                    </div>
                }
            </article>

            <article class="brief-panel">
                <h2>Export-ready Markdown</h2>
                <pre>@_result.AccountabilityBriefMarkdown</pre>
            </article>
        </section>
    }
</main>

@code {
    [Parameter]
    public Guid ReportId { get; set; }

    private ReportPipelineResultDto? _result;
    private ReportDto? _report;
    private bool _isLoading = true;

    private string BriefTitle => _report?.Status == ReportStatus.Approved
        ? "Validation-backed accountability brief"
        : "Draft accountability brief";

    private string BriefLede => _report?.Status == ReportStatus.Approved
        ? "This output has an approved report behind it, but still requires responsible partner review before escalation."
        : "This output is an internal draft. Human validation is required before escalation.";

    private string BriefSafetyTitle => _report?.Status == ReportStatus.Approved
        ? "Validated report"
        : "Draft/unvalidated output";

    private string BriefSafetyBody => _report?.Status == ReportStatus.Approved
        ? "The underlying report has passed human validation. Use this brief for responsible review, partner coordination, and escalation planning."
        : "This brief is generated assistance. It is not a legal finding, verified evidence, or authorization to escalate without human validation and community safety review.";

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        try
        {
            _report = await ApiClient.GetReportAsync(ReportId);
            _result = await ApiClient.GetPipelineResultAsync(ReportId);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
