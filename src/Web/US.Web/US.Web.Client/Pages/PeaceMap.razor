@page "/map"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ClientAppLayout
@implements IAsyncDisposable
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@inject IJSRuntime JsRuntime
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.AppLanguageService Language
@inject Services.AppRoleService Roles
@inject Services.UiTextService Text
@inject NavigationManager Navigation

<PageTitle>@T("Map.Title") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <section class="hero-band dashboard-hero">
        <div>
            <p class="eyebrow">@T("Map.Eyebrow")</p>
            <h1>@T("Map.Title")</h1>
            <p class="lede">@T("Map.Lede")</p>
        </div>
        <div class="map-legend">
            <span><i class="zone-dot conflict-dot"></i> @T("Map.ConflictZone")</span>
            <span><i class="zone-dot resilience-dot"></i> @T("Map.ResilienceZone")</span>
        </div>
    </section>

    <section class="map-layout">
        <article id="@MapElementId" class="peace-map leaflet-peace-map"></article>

        <article class="context-panel">
            <p class="eyebrow">@_selected.Type</p>
            <h2>@_selected.Name</h2>
            <p>@_selected.Summary</p>
            <dl>
                <dt>@T("Common.Region")</dt>
                <dd>@_selected.Region</dd>
                <dt>@T("Map.Evidence")</dt>
                <dd>@_selected.Evidence</dd>
                <dt>@T("Map.Signal")</dt>
                <dd>@_selected.Signal</dd>
            </dl>
        </article>
    </section>
</main>

@code {
    private const string MapElementId = "peace-map-canvas";
    private ZoneView _selected = default!;
    private string _language = "en";
    private IJSObjectReference? _mapModule;
    private DotNetObjectReference<PeaceMap>? _dotNetReference;

    private readonly List<ZoneView> _zones =
    [
        new("Conflict", "Sahel water commitment gap", "Sahel", "Broken promise", "3 community reports reference a delayed water point linked to a local development commitment.", "Mining/CDA promise tracking", 14.5, -3.5, "C", "conflict-zone"),
        new("Resilience", "Women-led market mediation", "Sahel", "Mediation success", "Women mediators reopened a shared market route after farmer-herder tensions.", "Women-led peace infrastructure", 13.8, -1.5, "R", "resilience-zone"),
        new("Conflict", "Eastern DRC extraction dispute", "Eastern DRC", "Resource conflict", "Reports describe extraction without clear community benefit delivery.", "Resource justice", -1.6, 29.2, "C", "conflict-zone"),
        new("Resilience", "Youth early-warning circle", "Mozambique", "Community resilience", "Youth organizers coordinate alerts and safe routes during recovery periods.", "Youth-led resilience", -18.7, 35.5, "R", "resilience-zone")
    ];

    protected override async Task OnInitializedAsync()
    {
        await Language.InitializeAsync(JsRuntime);
        await Roles.InitializeAsync(JsRuntime);
        if (Roles.IsReporter)
        {
            Navigation.NavigateTo("/");
            return;
        }

        _language = Language.CurrentLanguage;
        Language.LanguageChanged += HandleLanguageChanged;

        var reports = await ApiClient.GetReportsAsync();
        foreach (var report in reports.Take(12))
        {
            _zones.Add(FromReport(report, _zones.Count));
        }

        _selected = _zones[0];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _dotNetReference = DotNetObjectReference.Create(this);
        _mapModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./peaceMap.js");
        await _mapModule.InvokeVoidAsync("initializePeaceMap", MapElementId, _zones, _dotNetReference);
    }

    [JSInvokable]
    public async Task SelectZone(int index)
    {
        if (index < 0 || index >= _zones.Count)
        {
            return;
        }

        _selected = _zones[index];
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        Language.LanguageChanged -= HandleLanguageChanged;

        if (_mapModule is not null)
        {
            await _mapModule.InvokeVoidAsync("disposePeaceMap", MapElementId);
            await _mapModule.DisposeAsync();
        }

        _dotNetReference?.Dispose();
    }

    private string T(string key) => Text.Text(_language, key);

    private void HandleLanguageChanged()
    {
        _language = Language.CurrentLanguage;
        _ = InvokeAsync(StateHasChanged);
    }

    private sealed record ZoneView(
        string Type,
        string Name,
        string Region,
        string Evidence,
        string Summary,
        string Signal,
        double Latitude,
        double Longitude,
        string Label,
        string CssClass);

    private static ZoneView FromReport(ReportDto report, int index)
    {
        var isResilience = report.IssueType is IssueType.MediationSuccess or IssueType.CommunityResilience or IssueType.RecoveryNeed;
        var (lat, lng, region) = RegionPoint(report.RegionCode);
        var offset = ((index % 5) - 2) * 0.18;

        return new ZoneView(
            isResilience ? "Resilience" : "Conflict",
            report.Location.Name,
            region,
            FormatIssue(report.IssueType),
            report.Description,
            $"Live report · {report.Status} · {report.Urgency}",
            lat + offset,
            lng + offset,
            isResilience ? "R" : "C",
            isResilience ? "resilience-zone" : "conflict-zone");
    }

    private static (double Latitude, double Longitude, string Region) RegionPoint(string regionCode) => regionCode switch
    {
        "drc" => (-1.6, 29.2, "Eastern DRC"),
        "sudan" => (13.8, 30.2, "Sudan"),
        "mozambique" => (-18.7, 35.5, "Mozambique"),
        _ => (14.5, -3.5, "Sahel")
    };

    private static string FormatIssue(IssueType issueType) => issueType switch
    {
        IssueType.BrokenPromise => "Broken promise",
        IssueType.ResourceConflict => "Resource conflict",
        IssueType.SecurityConcern => "Security concern",
        IssueType.EnvironmentalHarm => "Environmental harm",
        IssueType.MediationSuccess => "Mediation success",
        IssueType.CommunityResilience => "Community resilience",
        _ => issueType.ToString()
    };
}
