@page "/validate"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ClientAppLayout
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@using MudBlazor
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.UiTextService Text
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>@T("Validate.Title") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <section class="hero-band dashboard-hero">
        <div>
            <p class="eyebrow">@T("Validate.Eyebrow")</p>
            <h1>@T("Validate.Title")</h1>
            <p class="lede">@T("Validate.Lede")</p>
        </div>
        <div class="page-controls">
            <MudSelect T="string" @bind-Value="_language" Label="@T("Common.Language")" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="language-select">
                <MudSelectItem Value="@("en")">English</MudSelectItem>
                <MudSelectItem Value="@("fr")">French</MudSelectItem>
            </MudSelect>
        </div>
    </section>

    <section class="safety-note">
        <strong>@T("Validate.SafetyTitle")</strong>
        @T("Validate.SafetyBody")
    </section>

    <section class="validation-toolbar">
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadReportsAsync" Disabled="@_isLoading">
            @(_isLoading ? T("Common.Refreshing") : T("Common.Refresh"))
        </MudButton>
        <span>@WorkQueueReports.Count @T("Validate.WorkQueue")</span>
    </section>

    <section class="table-surface">
        @if (_isLoading)
        {
            <article class="empty-state">
                <h2>@T("Validate.LoadingTitle")</h2>
                <p>@T("Validate.LoadingBody")</p>
            </article>
        }
        else if (WorkQueueReports.Count == 0)
        {
            <article class="empty-state">
                <h2>@T("Validate.EmptyTitle")</h2>
                <p>@T("Validate.EmptyBody")</p>
            </article>
        }
        else
        {
            <MudTable T="ReportDto" Items="WorkQueueReports" Dense="true" Hover="true" Elevation="0" Class="review-table">
                <HeaderContent>
                    <MudTh>@T("Common.Region")</MudTh>
                    <MudTh>@T("Common.Location")</MudTh>
                    <MudTh>@T("Common.Urgency")</MudTh>
                    <MudTh>@T("Submit.WhatHappened")</MudTh>
                    <MudTh Class="actions-column">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@T("Common.Region")">@RegionLabel(context.RegionCode)</MudTd>
                    <MudTd DataLabel="@T("Common.Location")">@context.Location.Name</MudTd>
                    <MudTd DataLabel="@T("Common.Urgency")">
                        <MudChip T="string" Size="Size.Small" Color="@UrgencyColor(context.Urgency)" Variant="Variant.Filled">@Text.Urgency(_language, context.Urgency)</MudChip>
                    </MudTd>
                    <MudTd DataLabel="@T("Submit.WhatHappened")">
                        <span class="table-description">@Preview(context.Description)</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Class="actions-column">
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => OpenReviewAsync(context))">View</MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </section>
</main>

@code {
    private readonly Dictionary<Guid, string?> _notes = [];
    private IReadOnlyList<ReportDto> _reports = [];
    private bool _isLoading;
    private string _language = "en";

    private List<ReportDto> WorkQueueReports => _reports
        .Where(report => report.Status is ReportStatus.PendingValidation or ReportStatus.NeedsFollowUp)
        .OrderByDescending(report => report.SubmittedAt)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadReportsAsync();
    }

    private async Task LoadReportsAsync()
    {
        _isLoading = true;

        try
        {
            _reports = await ApiClient.GetReportsAsync();
            foreach (var report in _reports)
            {
                _notes.TryAdd(report.Id, report.ValidatorNotes);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenReviewAsync(ReportDto report)
    {
        var parameters = new DialogParameters<ValidationReviewDialog>
        {
            { dialog => dialog.Report, report },
            { dialog => dialog.Language, _language },
            { dialog => dialog.InitialNotes, _notes.GetValueOrDefault(report.Id) }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<ValidationReviewDialog>(T("Validate.Eyebrow"), parameters, options);
        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: ValidationReviewDialog.ValidationReviewResult review })
        {
            return;
        }

        await DecideAsync(report.Id, review);
    }

    private async Task DecideAsync(Guid reportId, ValidationReviewDialog.ValidationReviewResult review)
    {
        try
        {
            var updated = await ApiClient.ValidateReportAsync(reportId, new ValidateReportRequest
            {
                Decision = review.Decision,
                Notes = BuildValidationNotes(review)
            });

            _reports = _reports
                .Select(report => report.Id == updated.Id ? updated : report)
                .ToList();

            var message = Text.Format(_language, "Validate.Marked", updated.Id, Text.Status(_language, updated.Status));
            Snackbar.Add(message, Severity.Success);
            await ShowFeedbackAsync(T("Validate.ActionCompleteTitle"), T("Validate.ActionCompleteBody"), Icons.Material.Filled.CheckCircle, Color.Success);
        }
        catch
        {
            var message = T("Validate.ActionFailed");
            Snackbar.Add(message, Severity.Error);
            await ShowFeedbackAsync(T("Common.Error"), message, Icons.Material.Filled.Error, Color.Error);
        }
    }

    private string T(string key) => Text.Text(_language, key);

    private static string BuildValidationNotes(ValidationReviewDialog.ValidationReviewResult review)
    {
        var checklistSummary =
            $"Checks: consent={(review.ConsentConfirmed ? "yes" : "no")}; location={(review.LocationChecked ? "yes" : "no")}; evidence={(review.EvidenceChecked ? "yes" : "no")}; safety={(review.SafetyChecked ? "yes" : "no")}.";

        return string.IsNullOrWhiteSpace(review.Notes) ? checklistSummary : $"{review.Notes.Trim()}\n{checklistSummary}";
    }

    private static string RegionLabel(string regionCode) => regionCode switch
    {
        "drc" => "Eastern DRC",
        "sahel" => "Sahel",
        "sudan" => "Sudan",
        "mozambique" => "Mozambique",
        _ => regionCode.ToUpperInvariant()
    };

    private static string Preview(string value)
    {
        const int maxLength = 170;
        return value.Length <= maxLength ? value : $"{value[..maxLength]}...";
    }

    private static Color UrgencyColor(UrgencyLevel urgency) => urgency switch
    {
        UrgencyLevel.Critical => Color.Error,
        UrgencyLevel.High => Color.Warning,
        UrgencyLevel.Low => Color.Success,
        _ => Color.Info
    };

    private async Task ShowFeedbackAsync(string title, string message, string icon, Color iconColor)
    {
        var parameters = new DialogParameters<ActionFeedbackDialog>
        {
            { dialog => dialog.Title, title },
            { dialog => dialog.Message, message },
            { dialog => dialog.Icon, icon },
            { dialog => dialog.IconColor, iconColor },
            { dialog => dialog.OkText, T("Common.Ok") }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = false
        };

        var dialog = await DialogService.ShowAsync<ActionFeedbackDialog>(string.Empty, parameters, options);
        await dialog.Result;
    }

}
