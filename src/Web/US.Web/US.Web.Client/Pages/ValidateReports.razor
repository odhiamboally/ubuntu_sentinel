@page "/validate"
@rendermode InteractiveWebAssembly
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.UiTextService Text

<PageTitle>@T("Validate.Title") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <section class="hero-band dashboard-hero">
        <div>
            <p class="eyebrow">@T("Validate.Eyebrow")</p>
            <h1>@T("Validate.Title")</h1>
            <p class="lede">@T("Validate.Lede")</p>
        </div>
        <div class="page-controls">
            <label>
                @T("Common.Language")
                <select @bind="_language">
                    <option value="en">English</option>
                    <option value="fr">French</option>
                </select>
            </label>
        </div>
    </section>

    <section class="validation-toolbar">
        <button type="button" @onclick="LoadReportsAsync" disabled="@_isLoading">@(_isLoading ? T("Common.Refreshing") : T("Common.Refresh"))</button>
        <span>@PendingReports.Count @T("Validate.Pending")</span>
    </section>

    <section class="report-list">
        @if (_isLoading)
        {
            <article class="empty-state">
                <h2>@T("Validate.LoadingTitle")</h2>
                <p>@T("Validate.LoadingBody")</p>
            </article>
        }
        else if (PendingReports.Count == 0)
        {
            <article class="empty-state">
                <h2>@T("Validate.EmptyTitle")</h2>
                <p>@T("Validate.EmptyBody")</p>
            </article>
        }
        else
        {
            @foreach (var report in PendingReports)
            {
                <article class="validation-card">
                    <div class="validation-main">
                        <p class="eyebrow">@report.RegionCode.ToUpperInvariant() · @Text.IssueType(_language, report.IssueType) · @report.Urgency</p>
                        <h2>@report.Location.Name</h2>
                        <p>@report.Description</p>
                        <div class="validation-tags">
                            @if (report.Actors.WomenLed)
                            {
                                <span>Women-led</span>
                            }
                            @if (report.Actors.YouthLed)
                            {
                                <span>Youth-led</span>
                            }
                            @if (report.IsSensitive)
                            {
                                <span>Sensitive</span>
                            }
                        </div>
                    </div>

                    <div class="validation-actions">
                        <label>
                            @T("Validate.Notes")
                            <textarea value="@GetNotes(report.Id)" @oninput="eventArgs => SetNotes(report.Id, eventArgs.Value?.ToString())" rows="4" placeholder="@T("Validate.NotesPlaceholder")"></textarea>
                        </label>
                        <div class="button-row">
                            <button type="button" class="approve" @onclick="() => DecideAsync(report.Id, ValidationDecision.Approve)">@T("Validate.Approve")</button>
                            <button type="button" class="follow-up" @onclick="() => DecideAsync(report.Id, ValidationDecision.NeedsFollowUp)">@T("Validate.FollowUp")</button>
                            <button type="button" class="reject" @onclick="() => DecideAsync(report.Id, ValidationDecision.Reject)">@T("Validate.Reject")</button>
                        </div>
                    </div>
                </article>
            }
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <section class="result-panel">@_message</section>
    }
</main>

@code {
    private readonly Dictionary<Guid, string?> _notes = [];
    private IReadOnlyList<ReportDto> _reports = [];
    private bool _isLoading;
    private string? _message;
    private string _language = "en";

    private List<ReportDto> PendingReports => _reports
        .Where(report => report.Status == ReportStatus.PendingValidation)
        .OrderByDescending(report => report.SubmittedAt)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadReportsAsync();
    }

    private async Task LoadReportsAsync()
    {
        _isLoading = true;
        _message = null;

        try
        {
            _reports = await ApiClient.GetReportsAsync();
            foreach (var report in _reports)
            {
                _notes.TryAdd(report.Id, report.ValidatorNotes);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string? GetNotes(Guid reportId)
    {
        _notes.TryAdd(reportId, null);
        return _notes[reportId];
    }

    private void SetNotes(Guid reportId, string? value)
    {
        _notes[reportId] = value;
    }

    private async Task DecideAsync(Guid reportId, ValidationDecision decision)
    {
        var updated = await ApiClient.ValidateReportAsync(reportId, new ValidateReportRequest
        {
            Decision = decision,
            Notes = _notes.GetValueOrDefault(reportId)
        });

        _reports = _reports
            .Select(report => report.Id == updated.Id ? updated : report)
            .ToList();

        _message = Text.Format(_language, "Validate.Marked", updated.Id, updated.Status);
    }

    private string T(string key) => Text.Text(_language, key);
}
