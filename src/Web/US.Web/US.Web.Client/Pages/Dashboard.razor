@page "/dashboard"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ClientAppLayout
@using Microsoft.AspNetCore.SignalR.Client
@using US.SharedKernel.Contracts.Reports
@using US.SharedKernel.Enums
@using MudBlazor
@inject Services.UbuntuSentinelApiClient ApiClient
@inject Services.OfflineReportQueue OfflineQueue
@inject Services.UiTextService Text
@inject Services.AppLanguageService Language
@inject Services.AppRoleService Roles
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>@T("Dashboard.Title") | Ubuntu Sentinel</PageTitle>

<main class="page-shell">
    <section class="hero-band dashboard-hero">
        <div>
            <p class="eyebrow">@T("Dashboard.Eyebrow")</p>
            <h1>@T("Dashboard.Title")</h1>
            <p class="lede">@T("Dashboard.Lede")</p>
        </div>
        <div class="page-controls">
            <MudChip T="string" Size="Size.Small" Color="@ConnectionColor" Variant="Variant.Filled">@ConnectionLabel</MudChip>
        </div>
    </section>

    <section class="dashboard-grid">
        <article class="metric-card">
            <span>@T("Dashboard.Total")</span>
            <strong>@_reports.Count</strong>
        </article>
        <article class="metric-card">
            <span>@T("Dashboard.PendingValidation")</span>
            <strong>@_reports.Count(report => report.Status == US.SharedKernel.Enums.ReportStatus.PendingValidation)</strong>
        </article>
        <article class="metric-card">
            <span>@T("Dashboard.HighCritical")</span>
            <strong>@_reports.Count(report => report.Urgency >= US.SharedKernel.Enums.UrgencyLevel.High)</strong>
        </article>
        <article class="metric-card">
            <span>@T("Dashboard.FollowUp")</span>
            <strong>@_reports.Count(report => report.Status == ReportStatus.NeedsFollowUp)</strong>
        </article>
        <article class="metric-card">
            <span>@T("Dashboard.Approved")</span>
            <strong>@_reports.Count(report => report.Status == ReportStatus.Approved)</strong>
        </article>
        <article class="metric-card metric-card-action">
            <span>@(_isOnline ? T("Common.Online") : T("Common.Offline")) · @_pendingCount @T("Common.Pending")</span>
            <MudButton Size="Size.Small"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SyncPendingAsync"
                       Disabled="@(_isSyncing || !_isOnline || _pendingCount == 0)">
                @(_isSyncing ? T("Common.Syncing") : T("Common.Sync"))
            </MudButton>
        </article>
    </section>
</main>

@code {
    private readonly List<ReportDto> _reports = [];
    private HubConnection? _hubConnection;
    private string _language = "en";
    private bool _isOnline = true;
    private bool _isSyncing;
    private int _pendingCount;
    private IJSObjectReference? _connectivityModule;
    private IJSObjectReference? _connectivityRegistration;
    private DotNetObjectReference<Dashboard>? _dotNetReference;

    private string ConnectionLabel => _hubConnection?.State switch
    {
        HubConnectionState.Connected => T("Dashboard.Live"),
        HubConnectionState.Connecting or HubConnectionState.Reconnecting => T("Dashboard.Connecting"),
        _ => T("Common.Offline")
    };

    private Color ConnectionColor => _hubConnection?.State == HubConnectionState.Connected
        ? Color.Success
        : Color.Warning;

    protected override async Task OnInitializedAsync()
    {
        await Language.InitializeAsync(JsRuntime);
        await Roles.InitializeAsync(JsRuntime);
        if (Roles.IsReporter)
        {
            Navigation.NavigateTo("/");
            return;
        }

        _language = Language.CurrentLanguage;
        Language.LanguageChanged += HandleLanguageChanged;

        _reports.Clear();
        _reports.AddRange(await ApiClient.GetReportsAsync());
        _pendingCount = await OfflineQueue.GetPendingCountAsync();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri(ApiClient.ApiBaseUri, "/hubs/reports"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<ReportDto>("ReportSubmitted", UpsertReport);
        _hubConnection.On<ReportDto>("ReportValidated", UpsertReport);
        _hubConnection.On<Guid>("ReportDeleted", RemoveReport);
        _hubConnection.Reconnecting += _ => InvokeAsync(StateHasChanged);
        _hubConnection.Reconnected += _ => InvokeAsync(StateHasChanged);
        _hubConnection.Closed += _ => InvokeAsync(StateHasChanged);

        try
        {
            await _hubConnection.StartAsync();
        }
        catch
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _connectivityModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./connectivity.js");
        _dotNetReference = DotNetObjectReference.Create(this);
        _connectivityRegistration = await _connectivityModule.InvokeAsync<IJSObjectReference>("register", _dotNetReference);
        _isOnline = await _connectivityModule.InvokeAsync<bool>("isOnline");
        if (_isOnline && _pendingCount > 0)
        {
            await SyncPendingAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task NotifyOnlineStatusChanged(bool isOnline)
    {
        _isOnline = isOnline;

        if (isOnline && _pendingCount > 0)
        {
            await SyncPendingAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncPendingAsync()
    {
        _isSyncing = true;

        try
        {
            var result = await OfflineQueue.SyncAsync();
            _pendingCount = await OfflineQueue.GetPendingCountAsync();
            var message = result.Remaining == 0
                ? Text.Format(_language, "Submit.SyncedAll", result.Synced)
                : Text.Format(_language, "Submit.SyncedSome", result.Synced, result.Attempted, result.Remaining);

            Snackbar.Add(message, result.Remaining == 0 ? Severity.Success : Severity.Warning);
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private void UpsertReport(ReportDto report)
    {
        var index = _reports.FindIndex(existing => existing.Id == report.Id);
        if (index >= 0)
        {
            _reports[index] = report;
        }
        else
        {
            _reports.Insert(0, report);
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private void RemoveReport(Guid reportId)
    {
        _reports.RemoveAll(report => report.Id == reportId);
        _ = InvokeAsync(StateHasChanged);
    }

    private string T(string key) => Text.Text(_language, key);

    private void HandleLanguageChanged()
    {
        _language = Language.CurrentLanguage;
        _ = InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        Language.LanguageChanged -= HandleLanguageChanged;

        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }

        if (_connectivityRegistration is not null)
        {
            await _connectivityRegistration.InvokeVoidAsync("dispose");
            await _connectivityRegistration.DisposeAsync();
        }

        if (_connectivityModule is not null)
        {
            await _connectivityModule.DisposeAsync();
        }

        _dotNetReference?.Dispose();
    }
}
