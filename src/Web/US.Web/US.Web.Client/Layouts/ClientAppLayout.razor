@inherits LayoutComponentBase

<ClientMudProviderHost />

<header class="topbar">
    <nav class="topbar-left" aria-label="Primary">
        <a href="/dashboard" class="brand">Ubuntu Sentinel</a>
        <div class="nav-dropdown">
            <MudButton Variant="Variant.Text" Size="Size.Small" Class="topbar-link nav-dropdown-trigger">Intake</MudButton>
            <div class="nav-dropdown-menu" role="menu">
                <MudButton Href="/intake/ussd" Variant="Variant.Text" Size="Size.Small" Class="nav-menu-item">USSD simulator</MudButton>
                <MudButton Href="/submit" Variant="Variant.Text" Size="Size.Small" Class="nav-menu-item">Web form</MudButton>
            </div>
        </div>
        <div class="nav-dropdown">
            <MudButton Variant="Variant.Text" Size="Size.Small" Class="topbar-link nav-dropdown-trigger">Reports</MudButton>
            <div class="nav-dropdown-menu" role="menu">
                <MudButton Href="/reports" Variant="Variant.Text" Size="Size.Small" Class="nav-menu-item">All reports</MudButton>
                <MudButton Href="/validate" Variant="Variant.Text" Size="Size.Small" Class="nav-menu-item">Validate</MudButton>
            </div>
        </div>
        <MudButton Href="/map" Variant="Variant.Text" Size="Size.Small" Class="topbar-link">Map</MudButton>
    </nav>
    <div class="topbar-right" aria-hidden="true"></div>
</header>

@Body
